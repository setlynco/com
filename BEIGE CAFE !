<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beige Café ✿</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Cormorant:ital,wght@0,400;0,500;1,400;1,500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#FDF8F0;--bg2:#F5EDD8;--bg3:#EDE0C4;--bg4:#E0D0A8;
  --cream:#FFFDF7;--white:#FFFFFF;
  --sage:#7BA86A;--sage2:#5A8C49;--sage3:#3D6830;
  --gold:#C49A30;--gold2:#A67C20;--gold3:#7A5A10;
  --brown:#5C3D20;--brown2:#3A2410;
  --pink:#F2B8C0;--pink2:#E8909C;--pink3:#C86878;
  --blue:#A8CCEC;--blue2:#78AADC;--blue3:#4888C4;
  --peach:#F5CCAA;--peach2:#E8AA80;
  --ink:#1E1408;--ink2:#4A3420;--ink3:#7A6040;--ink4:#AE9070;
  --shelf:#E8D8B8;--shelf2:#D4C098;
  --shadow:rgba(92,61,32,0.10);--shadow2:rgba(92,61,32,0.18);
  --r:16px;--r2:22px;--r3:32px;
}
html,body{height:100%;overflow:hidden;background:var(--bg)}
body{font-family:'Nunito',sans-serif;color:var(--ink)}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:rgba(92,61,32,0.18);border-radius:3px}

/* ===== FLOATING CHARACTERS ===== */
.chars-layer{position:fixed;inset:0;pointer-events:none;z-index:5;overflow:hidden}
.char{position:absolute;user-select:none}
/* Fish SVG */
.fish-char{animation:fishSwim 18s ease-in-out infinite}
@keyframes fishSwim{
  0%{transform:translate(0,0) scaleX(1)}
  20%{transform:translate(80px,-30px) scaleX(1)}
  40%{transform:translate(160px,20px) scaleX(1)}
  50%{transform:translate(200px,-10px) scaleX(-1)}
  70%{transform:translate(100px,30px) scaleX(-1)}
  85%{transform:translate(20px,-20px) scaleX(-1)}
  100%{transform:translate(0,0) scaleX(1)}
}
.fish2-char{animation:fishSwim2 22s ease-in-out infinite 4s}
@keyframes fishSwim2{
  0%{transform:translate(0,0) scaleX(-1)}
  25%{transform:translate(-60px,40px) scaleX(-1)}
  50%{transform:translate(-120px,-20px) scaleX(1)}
  75%{transform:translate(-40px,30px) scaleX(1)}
  100%{transform:translate(0,0) scaleX(-1)}
}
.fish3-char{animation:fishSwim3 25s ease-in-out infinite 8s}
@keyframes fishSwim3{
  0%{transform:translate(0,0) scaleX(1) rotate(0deg)}
  30%{transform:translate(50px,-50px) scaleX(1) rotate(5deg)}
  60%{transform:translate(100px,20px) scaleX(-1) rotate(-3deg)}
  100%{transform:translate(0,0) scaleX(1) rotate(0deg)}
}
.dog-char{animation:dogWiggle 3s ease-in-out infinite}
@keyframes dogWiggle{
  0%,100%{transform:rotate(-2deg) translateY(0)}
  25%{transform:rotate(2deg) translateY(-3px)}
  50%{transform:rotate(-1deg) translateY(0)}
  75%{transform:rotate(3deg) translateY(-2px)}
}
.bunny-char{animation:bunnyBob 2.5s ease-in-out infinite 0.5s}
@keyframes bunnyBob{
  0%,100%{transform:translateY(0) rotate(-1deg)}
  40%{transform:translateY(-5px) rotate(1deg)}
  70%{transform:translateY(-2px) rotate(0deg)}
}

/* ===== LOGIN ===== */
#login{position:fixed;inset:0;z-index:900;display:flex;align-items:center;justify-content:center;background:var(--bg2);transition:opacity 0.9s,transform 0.9s}
#login.out{opacity:0;transform:scale(1.05);pointer-events:none}
.l-bg-deco{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.l-deco{position:absolute;font-size:28px;opacity:0.15;animation:decoFloat 4s ease-in-out infinite}
@keyframes decoFloat{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-15px) rotate(10deg)}}
.lcard{
  position:relative;z-index:1;background:var(--cream);border-radius:var(--r3);
  padding:52px 60px;width:430px;text-align:center;
  border:2px solid rgba(196,154,48,0.25);
  box-shadow:0 0 0 6px rgba(196,154,48,0.06),0 24px 70px rgba(92,61,32,0.18);
}
.l-orn{font-size:22px;margin-bottom:16px;letter-spacing:6px}
.l-logo{font-family:'Libre Baskerville',serif;font-size:34px;color:var(--brown);letter-spacing:1px}
.l-logo em{color:var(--gold);font-style:italic}
.l-sub{font-family:'Cormorant',serif;font-style:italic;font-size:15px;color:var(--ink4);margin-top:6px;margin-bottom:36px;letter-spacing:1px}
.l-line{height:1px;background:linear-gradient(90deg,transparent,rgba(196,154,48,0.35),transparent);margin-bottom:28px}
.l-lbl{display:block;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--ink3);text-align:left;margin-bottom:6px;font-weight:700}
.l-inp{width:100%;padding:13px 17px;border:1.5px solid rgba(92,61,32,0.14);border-radius:14px;background:var(--bg2);font-family:'Nunito',sans-serif;font-size:14px;color:var(--ink);outline:none;margin-bottom:15px;transition:all 0.2s}
.l-inp:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(196,154,48,0.12);background:var(--cream)}
.l-btn{width:100%;padding:14px;background:linear-gradient(135deg,#D4AA38,#C49A30,#A67C20);color:#FFF6D8;border:none;border-radius:14px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:all 0.3s;box-shadow:0 4px 20px rgba(196,154,48,0.4),inset 0 1px 0 rgba(255,240,160,0.5);position:relative;overflow:hidden}
.l-btn::before{content:'';position:absolute;top:-50%;left:-60%;width:35%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,248,180,0.6),transparent);transform:skewX(-20deg);animation:lbtnShine 2.5s infinite 1s}
@keyframes lbtnShine{0%{left:-60%}100%{left:160%}}
.l-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(196,154,48,0.5)}
.l-err{font-size:12px;color:#c04040;margin-top:12px;min-height:18px;font-style:italic}
@keyframes cardShake{0%,100%{transform:translateX(0)}25%{transform:translateX(-8px)}75%{transform:translateX(8px)}}

/* ===== APP ===== */
#app{display:none;height:100vh;flex-direction:column}
#app.show{display:flex}

/* ===== NAV ===== */
.nav{flex-shrink:0;height:60px;background:var(--cream);border-bottom:2px solid rgba(92,61,32,0.08);display:flex;align-items:center;padding:0 28px;gap:3px;position:relative;z-index:50;box-shadow:0 2px 16px var(--shadow)}
.nav-brand{font-family:'Libre Baskerville',serif;font-size:19px;color:var(--brown);margin-right:auto;letter-spacing:0.5px;cursor:default}
.nav-brand em{color:var(--gold);font-style:italic}
.nav-brand span{font-size:16px;margin-left:2px}
.nb{padding:8px 14px;border-radius:20px;border:none;background:transparent;font-family:'Nunito',sans-serif;font-size:13px;font-weight:600;color:var(--ink3);cursor:pointer;transition:all 0.2s}
.nb:hover{background:var(--bg2);color:var(--ink)}
.nb.on{background:var(--brown);color:var(--cream)}
.nav-add{margin-left:10px;padding:8px 18px;border:none;border-radius:20px;background:linear-gradient(135deg,#D4AA38 0%,#C49A30 50%,#A67C20 100%);color:#FFF5D0;font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;cursor:pointer;transition:all 0.25s;box-shadow:0 3px 14px rgba(196,154,48,0.45),inset 0 1px 0 rgba(255,240,160,0.4);position:relative;overflow:hidden;letter-spacing:0.3px}
.nav-add::before{content:'';position:absolute;top:-50%;left:-70%;width:40%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,248,180,0.55),transparent);transform:skewX(-20deg);animation:shine 3s infinite 2s}
@keyframes shine{0%{left:-70%}100%{left:160%}}
.nav-add:hover{transform:translateY(-2px);box-shadow:0 6px 22px rgba(196,154,48,0.55)}

/* ===== PAGES ===== */
.page{display:none;flex:1;overflow-y:auto;padding:30px 36px;animation:pgIn 0.35s ease both}
.page.on{display:block}
@keyframes pgIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
#page-journal,#page-lexicon{padding:0;overflow:hidden}

/* ===== CARD BASE ===== */
.card{background:var(--cream);border-radius:var(--r2);border:1.5px solid rgba(92,61,32,0.08);box-shadow:0 4px 20px var(--shadow)}

/* ===== HOME ===== */
.home-top-row{display:grid;grid-template-columns:1.4fr 1fr;gap:18px;margin-bottom:18px}
.greeting-banner{font-family:'Libre Baskerville',serif;font-size:22px;color:var(--brown);font-style:italic;margin-bottom:6px}
.greeting-sub{font-size:13px;color:var(--ink4);margin-bottom:20px}

/* Word of the day */
.wotd-card{background:linear-gradient(135deg,var(--cream),var(--bg2));border-radius:var(--r2);border:1.5px solid rgba(196,154,48,0.25);padding:22px 24px;box-shadow:0 4px 20px var(--shadow);position:relative;overflow:hidden}
.wotd-card::before{content:'✦';position:absolute;right:16px;top:12px;font-size:24px;color:rgba(196,154,48,0.2)}
.wotd-label{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--gold2);font-weight:700;margin-bottom:8px}
.wotd-word{font-family:'Libre Baskerville',serif;font-size:26px;color:var(--brown);font-style:italic;margin-bottom:6px}
.wotd-def{font-size:13px;color:var(--ink3);line-height:1.6;font-family:'Cormorant',serif;font-style:italic}

/* Currently reading */
.curr-card{background:var(--cream);border-radius:var(--r2);border:1.5px solid rgba(92,61,32,0.08);padding:22px 24px;box-shadow:0 4px 20px var(--shadow)}
.curr-inner{display:flex;gap:18px}
.curr-cover{width:90px;height:130px;border-radius:10px;flex-shrink:0;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:28px;overflow:hidden;box-shadow:4px 5px 16px rgba(92,61,32,0.22)}
.curr-cover img{width:100%;height:100%;object-fit:cover}
.curr-info{flex:1}
.curr-sec-lbl{font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:var(--ink4);font-weight:700;margin-bottom:8px}
.curr-title{font-family:'Libre Baskerville',serif;font-size:17px;color:var(--ink);margin-bottom:3px;font-style:italic}
.curr-auth{font-size:12px;color:var(--ink4);margin-bottom:12px;font-family:'Cormorant',serif}
.pbar{height:6px;background:var(--bg3);border-radius:3px;overflow:hidden;margin-bottom:6px}
.pfill{height:100%;background:linear-gradient(90deg,var(--sage),var(--gold));border-radius:3px;transition:width 0.7s}
.ppct{font-size:11px;color:var(--ink4);font-weight:600}
.pinps{display:flex;gap:8px;align-items:center;margin-top:10px;flex-wrap:wrap}
.pinp{width:68px;padding:7px 10px;border:1.5px solid rgba(92,61,32,0.15);border-radius:10px;font-size:13px;font-family:'Nunito',sans-serif;color:var(--ink);background:var(--bg2);text-align:center;outline:none;transition:border-color 0.2s}
.pinp:focus{border-color:var(--gold)}
.upd-btn{padding:7px 16px;border:1.5px solid var(--sage);border-radius:10px;background:transparent;color:var(--sage2);font-size:12px;font-family:'Nunito',sans-serif;cursor:pointer;font-weight:700;transition:all 0.2s}
.upd-btn:hover{background:var(--sage);color:white}
.goal-row{display:flex;align-items:center;gap:8px;margin-top:12px;padding-top:12px;border-top:1px solid var(--bg3);flex-wrap:wrap}
.goal-lbl{font-size:12px;color:var(--ink4)}
.goal-badge{font-size:11px;padding:4px 12px;background:var(--bg2);border-radius:20px;color:var(--ink3);border:1px solid var(--bg4);font-weight:600}

/* Stats */
.stats-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-bottom:18px}
.stat-box{background:var(--cream);border-radius:var(--r);padding:18px;border:1.5px solid rgba(92,61,32,0.07);text-align:center;box-shadow:0 2px 10px var(--shadow)}
.stat-n{font-family:'Libre Baskerville',serif;font-size:28px;color:var(--brown)}
.stat-l{font-size:10px;color:var(--ink4);letter-spacing:1.5px;text-transform:uppercase;margin-top:4px;font-weight:700}

/* Home shelf */
.shelf-wrap{background:var(--cream);border-radius:var(--r2);border:1.5px solid rgba(92,61,32,0.08);padding:22px 24px 18px;box-shadow:0 4px 20px var(--shadow)}
.shelf-label{font-family:'Libre Baskerville',serif;font-size:14px;color:var(--brown);margin-bottom:14px;font-style:italic;display:flex;justify-content:space-between;align-items:center}
.shelf-row{display:flex;align-items:flex-end;gap:0;position:relative;padding-bottom:14px;overflow-x:auto}
.shelf-row::after{content:'';position:absolute;bottom:0;left:-4px;right:-4px;height:9px;background:linear-gradient(180deg,var(--shelf),var(--shelf2));border-radius:2px;box-shadow:0 4px 10px rgba(92,61,32,0.15)}
.sbook{flex-shrink:0;width:66px;cursor:pointer;transition:transform 0.25s;position:relative}
.sbook:hover{transform:translateY(-10px)}
.sbook-spine{width:54px;height:86px;border-radius:6px 6px 4px 4px;margin:0 6px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:3px 4px 12px rgba(92,61,32,0.22),inset -2px 0 5px rgba(0,0,0,0.08);border:1px solid rgba(92,61,32,0.1)}
.sbook-spine img{width:100%;height:100%;object-fit:cover}
.sbook-tt{position:absolute;bottom:calc(100% + 8px);left:50%;transform:translateX(-50%);background:var(--brown2);color:var(--bg2);font-size:10px;padding:4px 9px;border-radius:7px;white-space:nowrap;opacity:0;transition:opacity 0.2s;pointer-events:none;z-index:10;font-weight:600;max-width:100px;text-align:center}
.sbook:hover .sbook-tt{opacity:1}

/* ===== TIMELINE ===== */
.tl-tabs{display:flex;gap:8px;margin-bottom:22px;flex-wrap:wrap}
.tbtn{padding:8px 18px;border-radius:20px;border:1.5px solid rgba(92,61,32,0.16);background:transparent;font-size:13px;font-weight:700;color:var(--ink3);cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif}
.tbtn.on{background:var(--brown);color:var(--cream);border-color:var(--brown)}
.chart-card{background:var(--cream);border-radius:var(--r2);padding:24px;border:1.5px solid rgba(92,61,32,0.07);box-shadow:0 4px 20px var(--shadow);margin-bottom:18px}
.chart-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
.chart-ttl{font-family:'Libre Baskerville',serif;font-size:16px;color:var(--brown);font-style:italic}
.chart-sub{font-size:12px;color:var(--ink4);font-weight:600}
.tl-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.tl-item{background:var(--bg2);border-radius:12px;padding:12px 14px;display:flex;gap:12px;align-items:center}
.tl-cov{width:38px;height:54px;border-radius:5px;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;overflow:hidden;box-shadow:2px 3px 8px var(--shadow)}
.tl-cov img{width:100%;height:100%;object-fit:cover}
.tl-info h4{font-size:13px;font-weight:700;color:var(--ink);margin-bottom:2px}
.tl-info p{font-size:11px;color:var(--ink4);font-family:'Cormorant',serif;font-style:italic}

/* Reading Tracker */
.tracker-card{background:var(--cream);border-radius:var(--r2);padding:24px;border:1.5px solid rgba(92,61,32,0.07);box-shadow:0 4px 20px var(--shadow);margin-top:18px}
.tracker-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}
.tracker-ttl{font-family:'Libre Baskerville',serif;font-size:16px;color:var(--brown);font-style:italic}
.session-row{background:var(--bg2);border-radius:12px;padding:14px 16px;display:flex;gap:14px;align-items:center;margin-bottom:10px}
.sess-cover{width:40px;height:58px;border-radius:6px;background:var(--bg3);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;overflow:hidden;box-shadow:2px 3px 8px var(--shadow)}
.sess-cover img{width:100%;height:100%;object-fit:cover}
.sess-info{flex:1}
.sess-title{font-weight:700;font-size:13px;color:var(--ink);margin-bottom:4px}
.sess-dates{font-size:11px;color:var(--ink4);font-family:'Cormorant',serif;font-style:italic;margin-bottom:8px}
.sess-inputs{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.sess-inp{width:70px;padding:6px 10px;border:1.5px solid rgba(92,61,32,0.15);border-radius:9px;font-size:12px;font-family:'Nunito',sans-serif;background:var(--cream);color:var(--ink);text-align:center;outline:none}
.sess-inp:focus{border-color:var(--gold)}
.sess-btn{padding:6px 14px;border:1.5px solid var(--sage);border-radius:9px;background:transparent;color:var(--sage2);font-size:11px;font-family:'Nunito',sans-serif;cursor:pointer;font-weight:700;transition:all 0.2s}
.sess-btn:hover{background:var(--sage);color:white}
.sess-log{font-size:11px;color:var(--ink4);font-family:'Cormorant',serif;font-style:italic;margin-top:4px}
.add-session-btn{padding:10px 20px;border:1.5px dashed rgba(92,61,32,0.2);border-radius:12px;background:transparent;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;color:var(--ink3);cursor:pointer;width:100%;transition:all 0.2s}
.add-session-btn:hover{border-color:var(--sage);color:var(--sage2)}

/* ===== MILESTONES ===== */
.ms-top{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:28px}
.ms-n{font-family:'Libre Baskerville',serif;font-size:52px;color:var(--brown);line-height:1}
.ms-shelf-wrap{background:var(--cream);border-radius:var(--r2);padding:26px 28px 20px;border:1.5px solid rgba(92,61,32,0.08);box-shadow:0 4px 20px var(--shadow)}
.ms-row{display:flex;align-items:flex-end;gap:0;padding-bottom:16px;position:relative;overflow-x:auto}
.ms-row::after{content:'';position:absolute;bottom:0;left:-4px;right:0;height:9px;background:linear-gradient(180deg,var(--shelf),var(--shelf2));border-radius:2px;box-shadow:0 4px 10px rgba(92,61,32,0.15);z-index:0}
.ms-book{flex-shrink:0;width:78px;cursor:pointer;transition:transform 0.25s;position:relative;text-align:center}
.ms-book:hover{transform:translateY(-10px)}
.ms-cover{width:62px;height:92px;border-radius:6px 6px 4px 4px;margin:0 8px;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:3px 5px 14px rgba(92,61,32,0.22),inset -2px 0 5px rgba(0,0,0,0.07);border:1px solid rgba(92,61,32,0.1);position:relative;z-index:1}
.ms-cover img{width:100%;height:100%;object-fit:cover}
.ms-stars{font-size:9px;color:var(--gold);margin-top:6px;letter-spacing:1px;position:relative;z-index:1}
.ms-btitle{font-size:9px;color:var(--ink4);margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;padding:0 2px;position:relative;z-index:1;font-weight:600}

/* ===== JOURNAL - NEW DESIGN ===== */
#page-journal{position:relative}
.j-outer{height:calc(100vh - 60px);display:flex;overflow:hidden;position:relative}
.j-bg{position:absolute;inset:0;pointer-events:none;z-index:0}
.j-stickers-layer{position:absolute;inset:0;pointer-events:none;z-index:1}
.j-sticker{position:absolute;animation:jsfloat ease-in-out infinite;opacity:0.4}
@keyframes jsfloat{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-14px) rotate(8deg)}}

/* Right sidebar - categories */
.j-sidebar{width:200px;flex-shrink:0;padding:28px 16px;position:relative;z-index:3;background:rgba(253,248,240,0.85);backdrop-filter:blur(8px);border-left:1.5px solid rgba(92,61,32,0.1);display:flex;flex-direction:column;gap:12px;justify-content:center}
.j-cat-btn{
  padding:16px 14px;border-radius:18px;border:1.5px solid rgba(92,61,32,0.12);
  background:var(--cream);cursor:pointer;transition:all 0.3s;text-align:left;
  font-family:'Nunito',sans-serif;box-shadow:0 2px 10px var(--shadow);
  position:relative;overflow:hidden;
}
.j-cat-btn.on{border-color:var(--gold);box-shadow:0 4px 18px rgba(196,154,48,0.25);background:linear-gradient(135deg,#FFF8E8,#FFF2CC)}
.j-cat-num{font-size:28px;font-weight:800;color:var(--bg4);line-height:1;margin-bottom:6px;font-family:'Libre Baskerville',serif}
.j-cat-btn.on .j-cat-num{color:var(--gold)}
.j-cat-name{font-size:12px;font-weight:700;color:var(--ink3);line-height:1.3}
.j-cat-btn.on .j-cat-name{color:var(--brown)}
.j-cat-count{font-size:10px;color:var(--ink4);margin-top:4px;font-style:italic}
.j-cat-emoji{font-size:20px;margin-bottom:6px}

/* Journal main area */
.j-main{flex:1;padding:28px 28px 28px 32px;overflow-y:auto;position:relative;z-index:3}
.j-topbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;padding-bottom:18px;border-bottom:1.5px solid rgba(92,61,32,0.08)}
.j-title-block h2{font-family:'Libre Baskerville',serif;font-size:26px;color:var(--brown);font-style:italic}
.j-title-block p{font-size:12px;color:var(--ink4);margin-top:4px;letter-spacing:1px;text-transform:uppercase;font-weight:600}
.j-new-btn{padding:10px 20px;background:var(--cream);border:1.5px solid rgba(92,61,32,0.2);border-radius:20px;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;color:var(--brown);cursor:pointer;transition:all 0.2s}
.j-new-btn:hover{border-color:var(--gold);background:linear-gradient(135deg,#FFF8E8,#FFF2CC);box-shadow:0 4px 14px rgba(196,154,48,0.2)}

/* Journal entries grid */
.j-entries{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.j-card{
  background:rgba(255,253,247,0.92);border-radius:18px;padding:20px;
  border:1.5px solid rgba(92,61,32,0.09);cursor:pointer;
  transition:transform 0.25s,box-shadow 0.25s;
  backdrop-filter:blur(6px);
}
.j-card:hover{transform:translateY(-5px);box-shadow:0 14px 36px rgba(92,61,32,0.14)}
.j-card-cat{display:inline-block;font-size:9px;letter-spacing:2px;text-transform:uppercase;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:10px}
.cat-1{background:#FFF0D8;color:#9A6010;border:1px solid rgba(196,154,48,0.3)}
.cat-2{background:#E8F4E8;color:#3A6030;border:1px solid rgba(122,168,106,0.3)}
.cat-3{background:#F0E8F8;color:#6030A0;border:1px solid rgba(160,120,200,0.3)}
.j-card-date{font-size:10px;color:var(--ink4);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:8px;font-weight:600}
.j-card-title{font-family:'Libre Baskerville',serif;font-size:16px;color:var(--brown);margin-bottom:8px;font-style:italic;line-height:1.3}
.j-card-body{font-family:'Cormorant',serif;font-size:15px;color:var(--ink2);line-height:1.7;overflow:hidden;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical}
.j-card-footer{display:flex;justify-content:space-between;align-items:center;margin-top:14px;padding-top:12px;border-top:1px solid rgba(92,61,32,0.07)}
.j-card-mood{font-size:18px}
.j-card-acts{display:flex;gap:6px}
.j-act{padding:4px 11px;border-radius:8px;border:1px solid rgba(92,61,32,0.14);background:transparent;font-size:11px;color:var(--ink4);cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif;font-weight:600}
.j-act:hover{background:var(--bg2);color:var(--ink)}
.j-act.del:hover{background:#fee8e8;color:#b04040;border-color:#f5c0c0}
.j-empty{font-family:'Cormorant',serif;font-style:italic;font-size:16px;color:var(--ink4);padding:30px;background:rgba(255,253,247,0.8);border-radius:16px;text-align:center;grid-column:1/-1}

/* Entry full view modal */
.entry-view-bg{position:fixed;inset:0;background:rgba(30,20,8,0.6);z-index:600;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s;backdrop-filter:blur(8px)}
.entry-view-bg.open{opacity:1;pointer-events:all}
.entry-view{background:var(--cream);border-radius:var(--r3);padding:44px 48px;width:700px;max-height:85vh;overflow-y:auto;transform:translateY(20px) scale(0.97);transition:transform 0.35s cubic-bezier(.4,0,.2,1);position:relative}
.entry-view-bg.open .entry-view{transform:translateY(0) scale(1)}
.ev-cat{display:inline-block;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:700;padding:4px 12px;border-radius:20px;margin-bottom:16px}
.ev-date{font-size:11px;color:var(--ink4);letter-spacing:2px;text-transform:uppercase;margin-bottom:14px;font-weight:600}
.ev-title{font-family:'Libre Baskerville',serif;font-size:26px;color:var(--brown);font-style:italic;margin-bottom:20px;line-height:1.3}
.ev-body{font-family:'Cormorant',serif;font-size:18px;color:var(--ink2);line-height:1.9;white-space:pre-wrap}
.ev-footer{display:flex;align-items:center;gap:12px;margin-top:28px;padding-top:20px;border-top:1px solid var(--bg3)}
.ev-mood{font-size:24px}
.ev-close{position:absolute;top:18px;right:18px;background:transparent;border:none;font-size:18px;color:var(--ink4);cursor:pointer;padding:6px 10px;border-radius:9px;font-family:'Nunito',sans-serif;font-weight:700;transition:all 0.2s}
.ev-close:hover{background:var(--bg2);color:var(--ink)}

/* ===== LEXICON ===== */
#page-lexicon{overflow:visible}
#page-lexicon.on.page{padding:30px 36px;overflow-y:auto}
.lex-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px}
.lex-search{padding:10px 16px;border:1.5px solid rgba(92,61,32,0.14);border-radius:20px;font-family:'Nunito',sans-serif;font-size:13px;background:var(--cream);color:var(--ink);outline:none;width:240px;transition:border-color 0.2s}
.lex-search:focus{border-color:var(--gold)}
.lex-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
.lex-card{background:var(--cream);border-radius:var(--r);padding:18px 20px;border:1.5px solid rgba(92,61,32,0.08);box-shadow:0 2px 12px var(--shadow);transition:transform 0.2s,box-shadow 0.2s;cursor:default;position:relative;overflow:hidden}
.lex-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(92,61,32,0.14)}
.lex-card::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:linear-gradient(180deg,var(--gold),var(--sage))}
.lex-word{font-family:'Libre Baskerville',serif;font-size:18px;color:var(--brown);font-style:italic;margin-bottom:4px}
.lex-pos{font-size:10px;color:var(--gold2);letter-spacing:2px;text-transform:uppercase;font-weight:700;margin-bottom:8px}
.lex-def{font-family:'Cormorant',serif;font-size:15px;color:var(--ink2);line-height:1.6}
.lex-ex{font-family:'Cormorant',serif;font-style:italic;font-size:13px;color:var(--ink4);margin-top:8px;padding-top:8px;border-top:1px solid var(--bg3)}
.lex-del{position:absolute;top:10px;right:10px;background:transparent;border:none;font-size:14px;color:var(--ink4);cursor:pointer;padding:3px 6px;border-radius:6px;opacity:0;transition:all 0.2s}
.lex-card:hover .lex-del{opacity:1}
.lex-del:hover{background:#fee8e8;color:#c04040}
.lex-add-card{border:2px dashed rgba(92,61,32,0.16);border-radius:var(--r);padding:18px 20px;text-align:center;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:130px}
.lex-add-card:hover{border-color:var(--gold);background:rgba(196,154,48,0.04)}
.lex-add-icon{font-size:28px;color:var(--ink4);margin-bottom:8px}
.lex-add-lbl{font-size:13px;color:var(--ink4);font-weight:600}

/* ===== WISHLIST ===== */
.wish-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(156px,1fr));gap:16px}
.w-card{background:var(--cream);border-radius:var(--r);padding:18px;border:1.5px solid rgba(92,61,32,0.07);text-align:center;transition:transform 0.25s,box-shadow 0.25s;box-shadow:0 2px 12px var(--shadow)}
.w-card:hover{transform:translateY(-5px);box-shadow:0 12px 28px rgba(92,61,32,0.14)}
.w-cov{width:78px;height:112px;border-radius:8px;background:var(--bg3);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-size:26px;overflow:hidden;box-shadow:3px 4px 12px var(--shadow2)}
.w-cov img{width:100%;height:100%;object-fit:cover}
.w-name{font-family:'Libre Baskerville',serif;font-size:13px;color:var(--ink);margin-bottom:4px;font-style:italic}
.w-auth{font-size:11px;color:var(--ink4);margin-bottom:8px;font-family:'Cormorant',serif}
.w-cat{font-size:10px;padding:3px 10px;border-radius:20px;background:var(--bg2);color:var(--ink3);border:1px solid var(--bg4);font-weight:700}
.w-btns{display:flex;gap:6px;margin-top:10px;justify-content:center}
.mini-btn{padding:6px 12px;border:1.5px solid var(--sage);border-radius:20px;background:transparent;color:var(--sage2);font-size:11px;cursor:pointer;transition:all 0.2s;font-family:'Nunito',sans-serif;font-weight:700}
.mini-btn:hover{background:var(--sage);color:white}
.mini-btn.gold{border-color:var(--gold);color:var(--gold2)}
.mini-btn.gold:hover{background:var(--gold);color:white}
.w-add-card{border:2px dashed rgba(92,61,32,0.16);border-radius:var(--r);padding:18px;text-align:center;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:196px}
.w-add-card:hover{border-color:var(--gold);background:rgba(196,154,48,0.04)}

/* ===== MODALS ===== */
.mbg{position:fixed;inset:0;background:rgba(30,20,8,0.58);z-index:700;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.3s;backdrop-filter:blur(7px)}
.mbg.open{opacity:1;pointer-events:all}
.mbox{background:var(--cream);border-radius:var(--r3);padding:38px;transform:translateY(20px) scale(0.97);transition:transform 0.35s cubic-bezier(.4,0,.2,1);position:relative;max-height:90vh;overflow-y:auto;border:1.5px solid rgba(92,61,32,0.1);box-shadow:0 24px 70px rgba(92,61,32,0.22)}
.mbg.open .mbox{transform:translateY(0) scale(1)}
.m-close{position:absolute;top:16px;right:16px;background:transparent;border:none;font-size:18px;color:var(--ink4);cursor:pointer;padding:5px 9px;border-radius:9px;font-family:'Nunito',sans-serif;font-weight:700;transition:all 0.2s}
.m-close:hover{background:var(--bg2);color:var(--ink)}
.m-ttl{font-family:'Libre Baskerville',serif;font-size:22px;color:var(--brown);margin-bottom:24px;font-style:italic}
.fg{margin-bottom:15px}
.fl{display:block;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--ink4);margin-bottom:6px;font-weight:700}
.fi{width:100%;padding:11px 14px;border:1.5px solid rgba(92,61,32,0.16);border-radius:12px;font-family:'Nunito',sans-serif;font-size:13px;color:var(--ink);background:var(--bg2);outline:none;transition:border-color 0.2s;font-weight:600}
.fi:focus{border-color:var(--gold);background:var(--cream)}
.fi-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.star-row{display:flex;gap:6px;margin-top:4px}
.sbtn{font-size:22px;background:none;border:none;cursor:pointer;opacity:0.22;transition:all 0.15s;color:var(--gold)}
.sbtn.on{opacity:1}
.cov-drop{border:2px dashed rgba(92,61,32,0.18);border-radius:12px;padding:22px;text-align:center;cursor:pointer;transition:all 0.2s}
.cov-drop:hover{border-color:var(--gold);background:rgba(196,154,48,0.04)}
.cov-prev-img{width:76px;height:108px;border-radius:8px;object-fit:cover;box-shadow:2px 3px 10px var(--shadow2)}
.macts{display:flex;gap:10px;margin-top:24px;justify-content:flex-end}
.btn-c{padding:10px 20px;border:1.5px solid rgba(92,61,32,0.16);border-radius:12px;background:transparent;font-size:13px;color:var(--ink3);cursor:pointer;font-family:'Nunito',sans-serif;font-weight:700}
.btn-p{padding:10px 26px;background:linear-gradient(135deg,#D4AA38,#C49A30);color:#FFF5D0;border:none;border-radius:12px;font-size:13px;cursor:pointer;font-family:'Nunito',sans-serif;font-weight:800;transition:all 0.2s;box-shadow:0 3px 14px rgba(196,154,48,0.35)}
.btn-p:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(196,154,48,0.45)}

/* Journal modal */
.jm-canvas-top{position:absolute;top:0;left:0;right:0;height:55px;pointer-events:none;border-radius:var(--r3) var(--r3) 0 0;overflow:hidden;opacity:0.45}
.jm-ti{width:100%;border:none;background:transparent;font-family:'Libre Baskerville',serif;font-size:22px;color:var(--brown);outline:none;padding:10px 0;border-bottom:1.5px solid var(--bg3);margin-bottom:16px;font-style:italic}
.jm-bi{width:100%;border:none;background:transparent;font-family:'Cormorant',serif;font-size:17px;color:var(--ink);outline:none;resize:none;min-height:200px;line-height:1.9}
.jm-cats{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.jm-cat-opt{padding:6px 14px;border-radius:20px;border:1.5px solid rgba(92,61,32,0.16);background:transparent;font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all 0.2s;color:var(--ink3)}
.jm-cat-opt.on{border-color:var(--gold);background:linear-gradient(135deg,#FFF8E8,#FFF0CC);color:var(--brown)}
.jm-footer{display:flex;justify-content:space-between;align-items:center;margin-top:18px;padding-top:16px;border-top:1.5px solid var(--bg3)}
.mood-row{display:flex;gap:8px}
.mood-btn{font-size:22px;background:none;border:none;cursor:pointer;opacity:0.25;transition:all 0.2s}
.mood-btn.sel,.mood-btn:hover{opacity:1;transform:scale(1.2)}

/* Lexicon modal */
.lex-pos-opts{display:flex;gap:8px;flex-wrap:wrap;margin-top:4px}
.pos-opt{padding:5px 12px;border-radius:20px;border:1.5px solid rgba(92,61,32,0.16);background:transparent;font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all 0.2s;color:var(--ink3)}
.pos-opt.on{border-color:var(--gold);background:var(--bg2);color:var(--brown)}

/* Page headers */
.ph{margin-bottom:26px}
.ph h2{font-family:'Libre Baskerville',serif;font-size:26px;color:var(--brown);font-style:italic}
.ph p{font-size:13px;color:var(--ink4);margin-top:4px;font-weight:600}
</style>
</head>
