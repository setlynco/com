function removeBook(i){books.splice(i,1);persist();renderAll()}

/* ===== ADD BOOK ===== */
function openAdd(st){clickSnd();['ab-t','ab-a','ab-pg','ab-ds','ab-df'].forEach(id=>document.getElementById(id).value='');_rat=0;_cov='';document.querySelectorAll('.sbtn').forEach(s=>s.classList.remove('on'));document.getElementById('cov-prev').innerHTML='<div style="font-size:26px;margin-bottom:6px">📷</div><div style="font-size:12px;color:var(--ink4);font-weight:600">Click to upload</div>';if(st)document.getElementById('ab-st').value=st;document.getElementById('abmodal').classList.add('open')}
function closeAdd(){document.getElementById('abmodal').classList.remove('open');clickSnd()}
function setR(n){_rat=n;document.querySelectorAll('.sbtn').forEach((s,i)=>s.classList.toggle('on',i<n));clickSnd()}
function prevCov(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{_cov=ev.target.result;document.getElementById('cov-prev').innerHTML=`<img class="cov-prev-img" src="${_cov}">`};r.readAsDataURL(f)}
function saveBook(){
  const t=document.getElementById('ab-t').value.trim();if(!t){document.getElementById('ab-t').style.borderColor='var(--gold)';return}
  const st=document.getElementById('ab-st').value;
  const b={id:Date.now(),title:t,author:document.getElementById('ab-a').value.trim(),category:document.getElementById('ab-cat').value,status:st,pages:document.getElementById('ab-pg').value||null,rating:_rat||5,cover:_cov||null,currentPage:0,dateStarted:document.getElementById('ab-ds').value||null,dateFinished:document.getElementById('ab-df').value||(st==='finished'?todayISO():null)};
  if(st==='reading')books.forEach(x=>{if(x.status==='reading')x.status='paused'});
  books.unshift(b);persist();renderAll();closeAdd();successSnd();
}

/* ===== INIT ===== */
renderJournal();renderLexicon();
window.addEventListener('resize',()=>{if(document.getElementById('page-journal').classList.contains('on'))drawJBg();if(document.getElementById('page-timeline').classList.contains('on'))renderTimeline()});
</script>
