<script>
/* ===== AUDIO ===== */
let AC;
function gAC(){if(!AC)try{AC=new(window.AudioContext||window.webkitAudioContext)()}catch(e){}return AC}
function tone(f,d,t='sine',v=0.05){const ac=gAC();if(!ac)return;try{const o=ac.createOscillator(),g=ac.createGain();o.connect(g);g.connect(ac.destination);o.type=t;o.frequency.value=f;g.gain.setValueAtTime(0,ac.currentTime);g.gain.linearRampToValueAtTime(v,ac.currentTime+0.02);g.gain.exponentialRampToValueAtTime(0.001,ac.currentTime+d);o.start();o.stop(ac.currentTime+d)}catch(e){}}
function chime(){[523,659,784,1047].forEach((n,i)=>setTimeout(()=>tone(n,0.4,'sine',0.05),i*100))}
function clickSnd(){tone(520,0.1,'sine',0.035)}
function successSnd(){chime()}
function errorSnd(){tone(220,0.28,'sawtooth',0.04)}
function popSnd(){tone(660,0.12,'sine',0.04);setTimeout(()=>tone(880,0.1,'sine',0.03),80)}
function journalSnd(){[440,554,659].forEach((n,i)=>setTimeout(()=>tone(n,0.35,'sine',0.04),i*90))}
function pageSnd(){tone(380,0.08,'triangle',0.03);setTimeout(()=>tone(480,0.07,'triangle',0.025),55)}

/* ===== STATE ===== */
let books=JSON.parse(localStorage.getItem('bc3_books')||'[]');
let journals=JSON.parse(localStorage.getItem('bc3_jrnl')||'[]');
let lexicon=JSON.parse(localStorage.getItem('bc3_lex')||'[]');
let sessions=JSON.parse(localStorage.getItem('bc3_sess')||'[]');
let _rat=0,_cov='',_editJid=null,_mood='✨',_jcat='1',_tab='Annual',_jFilter='all',_pos='noun';
const persist=()=>{localStorage.setItem('bc3_books',JSON.stringify(books));localStorage.setItem('bc3_jrnl',JSON.stringify(journals));localStorage.setItem('bc3_lex',JSON.stringify(lexicon));localStorage.setItem('bc3_sess',JSON.stringify(sessions))};

/* ===== HELPERS ===== */
const catEmoji=c=>({'Fiction':'📚','Poetry':'🌿','Non-fiction':'💡','Self-development':'✨','Academic':'🎓','Biography':'🖊️','Philosophy':'🔮','Other':'📖'}[c]||'📖');
function todayFmt(){return new Date().toLocaleDateString('en-GB',{weekday:'long',day:'numeric',month:'long'})}
function todayISO(){return new Date().toISOString().split('T')[0]}
function greetWord(){const h=new Date().getHours();return h<12?'Good morning':h<18?'Good afternoon':'Good evening'}
function bookColor(b){return['#DDD0A8','#C8BC90','#BFAE80','#D0C4A0','#C4B888','#BAA870','#CABB98'][b.id%7]}
function jcatLabel(c){return{1:'Practice What You Read!',2:'Stream of Thoughts',3:'Character Study'}[c]||'General'}
function jcatClass(c){return{1:'cat-1',2:'cat-2',3:'cat-3'}[c]||'cat-1'}

/* Star drawing */
function drawStar(ctx,x,y,r,col){ctx.save();ctx.fillStyle=col;ctx.shadowColor=col;ctx.shadowBlur=r*3;ctx.beginPath();ctx.moveTo(x,y-r*2.3);for(let i=0;i<8;i++){ctx.rotate(Math.PI/4);ctx.lineTo(x,y-(i%2===0?r*2.3:r*0.9))}ctx.closePath();ctx.fill();ctx.restore()}

/* ===== LOGIN ===== */
document.addEventListener('keydown',e=>{if(e.key==='Enter'&&document.getElementById('login').offsetParent!==null)doLogin()});
function doLogin(){
  const u=document.getElementById('lu').value.trim();
  const p=document.getElementById('lp').value.trim();
  if(u.toLowerCase()==='dildorab'&&p==='1708'){
    successSnd();
    document.getElementById('login').classList.add('out');
    setTimeout(()=>{document.getElementById('login').style.display='none';document.getElementById('app').classList.add('show');initApp();},900);
  } else {
    errorSnd();
    document.getElementById('lerr').textContent='Incorrect — please try again ✦';
    document.querySelector('.lcard').style.animation='cardShake 0.4s ease';
    setTimeout(()=>document.querySelector('.lcard').style.animation='',450);
  }
}

/* ===== INIT ===== */
function initApp(){
  document.getElementById('greeting-h2').textContent=greetWord()+', Dilorom ✿';
  renderAll();
  setTimeout(()=>{drawJBg();spawnStickers();},150);
  showWOTD();
}

/* ===== NAV ===== */
function goPage(name,btn){
  pageSnd();
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  document.querySelectorAll('.nb').forEach(b=>b.classList.remove('on'));
  document.getElementById('page-'+name).classList.add('on');
  btn.classList.add('on');
  if(name==='journal')setTimeout(()=>{drawJBg();spawnStickers();renderJournal();},80);
  if(name==='timeline')renderTimeline();
  if(name==='milestones')renderMilestones();
  if(name==='wishlist')renderWishlist();
  if(name==='lexicon')renderLexicon();
}

function renderAll(){renderHome();renderMilestones();renderWishlist();renderTimeline();renderJournal();renderLexicon();renderSessions();}

/* ===== HOME ===== */
function renderHome(){
  const rd=books.find(b=>b.status==='reading');
