function drawJBg(){
  const cv=document.getElementById('j-canvas');if(!cv)return;
  const W=cv.parentElement.offsetWidth||900,H=cv.parentElement.offsetHeight||700;
  cv.width=W;cv.height=H;const ctx=cv.getContext('2d');ctx.clearRect(0,0,W,H);
  // Light grid background like the reference image
  ctx.strokeStyle='rgba(196,154,48,0.06)';ctx.lineWidth=1;
  const gs=40;for(let x=0;x<=W;x+=gs){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.stroke()}
  for(let y=0;y<=H;y+=gs){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke()}
  // Stars
  const stars=Array.from({length:50},()=>({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.8+0.9,b:Math.random()*0.5+0.3}));
  const groups=[[0,5,10,17,24],[2,8,14,20,26],[4,11,18,25,32],[35,40,45],[38,43,48]];
  ctx.strokeStyle='rgba(196,154,48,0.1)';ctx.lineWidth=0.8;
  groups.forEach(g=>{for(let i=0;i<g.length-1;i++){const a=stars[g[i]%stars.length],b=stars[g[i+1]%stars.length];ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.stroke()}});
  stars.forEach(s=>{ctx.save();ctx.globalAlpha=s.b*0.6;drawStar(ctx,s.x,s.y,s.r,'rgba(196,154,48,0.85)');ctx.restore()});
}
