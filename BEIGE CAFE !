function switchTab(name,btn){clickSnd();_tab=name;document.querySelectorAll('.tbtn').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderTimeline();}
function renderTimeline(){
  const fin=books.filter(b=>b.status==='finished');
  const now=new Date();let labels=[],values=[],period=fin;
  if(_tab==='Annual'){
    const yrs=[...new Set(fin.map(b=>b.dateFinished?new Date(b.dateFinished).getFullYear():now.getFullYear()))];
    if(!yrs.length){labels=[now.getFullYear()];values=[0]}
    else{const mn=Math.min(...yrs),mx=Math.max(...yrs);for(let y=mn;y<=mx;y++){labels.push(y);values.push(fin.filter(b=>b.dateFinished&&new Date(b.dateFinished).getFullYear()===y).length)}}
    document.getElementById('chart-ttl').textContent='Books Per Year';document.getElementById('chart-sub').textContent=`${fin.length} total`;
  } else if(_tab==='Monthly'){
    const ms=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    labels=ms;values=ms.map((_,i)=>fin.filter(b=>{if(!b.dateFinished)return false;const d=new Date(b.dateFinished);return d.getFullYear()===now.getFullYear()&&d.getMonth()===i}).length);
    period=fin.filter(b=>b.dateFinished&&new Date(b.dateFinished).getFullYear()===now.getFullYear());
    document.getElementById('chart-ttl').textContent='This Year by Month';document.getElementById('chart-sub').textContent=`${period.length} books`;
  } else if(_tab==='Weekly'){
    const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];labels=days;values=days.map(()=>0);
    document.getElementById('chart-ttl').textContent='This Week';document.getElementById('chart-sub').textContent='Activity';period=fin.slice(-5);
  } else {
    // Daily - last 30 days
    labels=Array.from({length:10},(_,i)=>{const d=new Date(now);d.setDate(d.getDate()-9+i);return `${d.getDate()}/${d.getMonth()+1}`});
    values=labels.map(()=>0);
    // Count sessions per day
    sessions.forEach(s=>{if(!s.date)return;const sd=new Date(s.date);const lbl=`${sd.getDate()}/${sd.getMonth()+1}`;const idx=labels.indexOf(lbl);if(idx>=0)values[idx]+=(s.pgs||0)/50});
    document.getElementById('chart-ttl').textContent='Daily Pages (last 10 days)';document.getElementById('chart-sub').textContent='Reading sessions';period=sessions.slice(-5).map(s=>({...books.find(b=>b.id===s.bookId)||{title:'Unknown',category:'Other'},_sess:s})).filter(x=>x);
  }
  drawLine(labels,values);
  const tb=document.getElementById('tl-books');
  if(_tab==='Daily'){
    if(!sessions.length){tb.innerHTML='<div style="font-size:13px;color:var(--ink4)">No sessions logged yet</div>';return}
    tb.innerHTML=sessions.slice().reverse().slice(0,6).map(s=>{const bk=books.find(b=>b.id===s.bookId)||{title:'Unknown',category:'Other',cover:null};return`<div class="tl-item"><div class="tl-cov">${bk.cover?`<img src="${bk.cover}">`:(catEmoji(bk.category))}</div><div class="tl-info"><h4>${bk.title}</h4><p>${s.date||''} · ${s.pgs||0} pages · ${s.dur||0}min</p><p style="margin-top:3px;color:var(--ink3)">${s.notes||''}</p></div></div>`}).join('');
    return;
  }
  if(!period.length){tb.innerHTML='<div style="font-size:13px;color:var(--ink4)">No books yet</div>';return}
  tb.innerHTML=period.map(b=>`<div class="tl-item"><div class="tl-cov">${b.cover?`<img src="${b.cover}">`:(catEmoji(b.category))}</div><div class="tl-info"><h4>${b.title}</h4><p>${b.author||''}</p><div class="tl-stars" style="color:var(--gold);font-size:11px">${'★'.repeat(b.rating||5)}</div></div></div>`).join('');
}
function drawLine(labels,values){
  const cv=document.getElementById('line-canvas');if(!cv)return;
  const W=cv.parentElement.offsetWidth-48,H=150;cv.width=W;cv.height=H;
  const ctx=cv.getContext('2d');ctx.clearRect(0,0,W,H);
  const p={l:36,r:20,t:18,b:28};const mx=Math.max(...values,1);
  const pts=labels.map((l,i)=>({x:p.l+(i/(labels.length-1||1))*(W-p.l-p.r),y:p.t+(1-values[i]/mx)*(H-p.t-p.b),v:values[i],l:String(l)}));
  ctx.strokeStyle='rgba(92,61,32,0.07)';ctx.lineWidth=1;
  for(let i=0;i<=4;i++){const y=p.t+i*(H-p.t-p.b)/4;ctx.beginPath();ctx.moveTo(p.l,y);ctx.lineTo(W-p.r,y);ctx.stroke()}
  const gr=ctx.createLinearGradient(0,p.t,0,H-p.b);gr.addColorStop(0,'rgba(123,168,106,0.28)');gr.addColorStop(1,'rgba(123,168,106,0)');
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);for(let i=1;i<pts.length;i++){const prev=pts[i-1],cpx=(prev.x+pts[i].x)/2;ctx.bezierCurveTo(cpx,prev.y,cpx,pts[i].y,pts[i].x,pts[i].y)}
  ctx.lineTo(pts[pts.length-1].x,H-p.b);ctx.lineTo(pts[0].x,H-p.b);ctx.closePath();ctx.fillStyle=gr;ctx.fill();
  ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);for(let i=1;i<pts.length;i++){const prev=pts[i-1],cpx=(prev.x+pts[i].x)/2;ctx.bezierCurveTo(cpx,prev.y,cpx,pts[i].y,pts[i].x,pts[i].y)}
  ctx.strokeStyle='rgba(123,168,106,0.9)';ctx.lineWidth=2.5;ctx.stroke();
  pts.forEach(pt=>{ctx.beginPath();ctx.arc(pt.x,pt.y,4,0,Math.PI*2);ctx.fillStyle='white';ctx.fill();ctx.strokeStyle='rgba(123,168,106,0.9)';ctx.lineWidth=2.2;ctx.stroke();ctx.fillStyle='rgba(92,61,32,0.45)';ctx.font='10px Nunito,sans-serif';ctx.textAlign='center';ctx.fillText(pt.l,pt.x,H-6);if(pt.v>0){ctx.fillStyle='rgba(92,61,32,0.7)';ctx.fillText(Math.round(pt.v),pt.x,pt.y-10)}});
}

